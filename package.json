    },
    "./types/families/d": {
      "types": "./dist/types/families/d.d.ts",
      "default": "./dist/types/families/d.js"
    },
    "./types/families/e": {
      "types": "./dist/types/families/e.d.ts",
      "default": "./dist/types/families/e.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./topology-overlay": {
      "types": "./dist/topology-overlay.d.ts",
      "default": "./dist/topology-overlay.js"
    },
    "./signal-classes": {
      "types": "./dist/signal-classes.d.ts",
      "default": "./dist/signal-classes.js"
    },
    "./verdict-groups": {
      "types": "./dist/verdict-groups.d.ts",
